# Database
DATABASE_URL=postgresql+asyncpg://reelvault:reelvault@localhost:5432/reelvault
DATABASE_SYNC_URL=postgresql+psycopg2://reelvault:reelvault@localhost:5432/reelvault

# Redis
REDIS_URL=redis://localhost:6379

# AI
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Cloudflare R2
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=reelvault
R2_PUBLIC_URL=https://your-bucket.r2.dev

# Sendblue
SENDBLUE_API_KEY=your_sendblue_api_key
SENDBLUE_API_SECRET=your_sendblue_api_secret
SENDBLUE_WEBHOOK_SECRET=your_sendblue_webhook_secret

# App
APP_URL=https://reelvault.up.railway.app
INTERNAL_CRON_SECRET=your_internal_cron_secret
